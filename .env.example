# Kopieer naar .env — waarden uit Firebase Console → Projectinstellingen → Web-app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Pad naar RTDB-node (radar pieken)
VITE_RTDB_PATH=radar/peaks

# Fallback timestamp-veldnaam op records
VITE_RTDB_TS_FIELD=timestamp

# Vernieuwen 4-uurs venster (ms)
VITE_WINDOW_TICK_MS=3000
